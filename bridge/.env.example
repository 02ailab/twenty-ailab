# Copy to .env on the VPS. Never commit .env. Secrets go in the k8s Secret.

# --- Chatwoot ---
CHATWOOT_BASE_URL=http://chatwoot.chatwoot.svc.cluster.local:3000
CHATWOOT_ACCOUNT_ID=replace-with-account-id
CHATWOOT_API_TOKEN=replace-with-chatwoot-access-token
CHATWOOT_WEBHOOK_SECRET=replace-with-webhook-hmac-secret
# Public host (NOT cluster DNS) — used for the "open chat" link on the Twenty card.
CHATWOOT_PUBLIC_URL=https://chat.saldo.chat

# --- Twenty ---
TWENTY_BASE_URL=http://twenty-server.twenty.svc.cluster.local:3000
TWENTY_API_KEY=replace-with-twenty-api-key
TWENTY_WEBHOOK_SECRET=replace-with-twenty-webhook-secret
# Replay/freshness window for /webhooks/twenty in seconds. 0 = disabled (enable, e.g.
# 300, only after confirming Twenty's timestamp semantics + node clock skew).
TWENTY_WEBHOOK_MAX_AGE_SECONDS=0
# API name of the Person "Links" field holding the Chatwoot link (create it once
# in Twenty: Settings -> Data model -> Person -> add field, type "Links").
TWENTY_CHATWOOT_FIELD=chatwoot
# saldoClientId (F1/F2): per-client number AAAA assigned once at Person creation + reverse-
# synced into Chatwoot `identifier`. In PROD this is set in the ConfigMap (deploy/k8s/
# twenty-bridge.yaml), NOT here — .env only feeds the k8s Secret. Listed here for local dev.
# Requires the Twenty Person NUMBER field whose API name = TWENTY_SALDO_CLIENT_ID_FIELD.
SALDO_CLIENT_ID_ENABLED=true
TWENTY_SALDO_CLIENT_ID_FIELD=saldoClientId
# CRM-FULL: real name + Telegram identity into the admin-only Twenty card. In PROD this is
# set in the ConfigMap. Requires the two TEXT fields (telegramUsername, telegramId) on Person.
CRM_FULL_ENABLED=true
TWENTY_TELEGRAM_USERNAME_FIELD=telegramUsername
TWENTY_TELEGRAM_ID_FIELD=telegramId
# §0.1 structured-log environment (production | local).
ENVIRONMENT=production

# --- Notes (Chatwoot conversation -> Twenty Note) ---
# On conversation resolve, write the transcript to a Twenty Note on the Person.
NOTE_SYNC_ENABLED=true
NOTE_MAX_MESSAGES=100

# --- Panel (public) ---
BRIDGE_PUBLIC_URL=https://bridge.saldo.chat
PANEL_SHARED_SECRET=replace-with-random-secret
# Short-lived token the page mints so the secret stops riding in /panel/api URLs.
PANEL_TOKEN_TTL_SECONDS=1800
# Per-IP cap on /panel/api/contact calls per minute (0 disables).
PANEL_RATE_LIMIT_PER_MINUTE=60

# --- Database (own Postgres) ---
POSTGRES_HOST=twenty-bridge-postgres
POSTGRES_PORT=5432
POSTGRES_USER=bridge
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=twenty_bridge

# --- Runtime ---
LOG_LEVEL=INFO
LOG_FORMAT=json
